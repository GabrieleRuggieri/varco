{
  "name": "varco",
  "version": "0.0.0",
  "private": true,
  "description": "Copilot AI di compliance per vendere in Europa",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev --concurrency=15",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,yaml,yml}\"",
    "typecheck": "turbo run typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "db:generate": "pnpm --filter @varco/database db:generate",
    "db:migrate": "pnpm --filter @varco/database db:migrate",
    "db:seed": "pnpm --filter @varco/database db:seed",
    "matrix:validate": "pnpm --filter @varco/matrix matrix:validate",
    "matrix:seed": "pnpm --filter @varco/matrix matrix:seed",
    "mock:build": "npm run build --prefix mocks/mock-server",
    "mock:dev": "npm run build --prefix mocks/mock-server && npm run start --prefix mocks/mock-server",
    "mock:test": "npm run test --prefix mocks/mock-server",
    "worker:enqueue-demo-sync": "pnpm --filter @varco/worker enqueue:demo-sync",
    "demo:populate": "pnpm db:seed && pnpm --filter @varco/worker populate:demo",
    "annotate": "node scripts/annotate-sources.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
