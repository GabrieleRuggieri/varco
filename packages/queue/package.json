{
  "name": "@varco/queue",
  "version": "0.0.0",
  "private": true,
  "description": "Client BullMQ condiviso — enqueue job worker",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@varco/shared": "workspace:*",
    "bullmq": "^5.53.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@varco/tsconfig": "workspace:*",
    "typescript": "^6.0.3"
  }
}
