{
  "name": "@varco/database",
  "version": "0.0.0",
  "private": true,
  "description": "Schema PostgreSQL, client Drizzle e migrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "db:generate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env --import tsx src/migrate.ts",
    "db:seed": "node --env-file=../../.env --import tsx src/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^26.0.0",
    "@varco/shared": "workspace:*",
    "@varco/tsconfig": "workspace:*",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  }
}
