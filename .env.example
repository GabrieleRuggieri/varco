# Database
DATABASE_URL=postgresql://varco:varco@localhost:5432/varco

# Redis
REDIS_URL=redis://localhost:6379

# Object storage (MinIO in locale)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=varco-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# LLM — mock in CI; ollama in dev; openai in staging/prod
LLM_PROVIDER=mock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OPENAI_API_KEY=

# Connettori catalogo — usa "mock" per sviluppo locale
SHOPIFY_API_MODE=mock
AMAZON_API_MODE=mock

# Partner RP/EPR
PARTNER_API_MODE=mock
MOCK_SERVER_URL=http://localhost:4010
PARTNER_WEBHOOK_DELAY_MS=5000
# Webhook partner → API Varco (mock server POST dopo delay)
VARCO_WEBHOOK_URL=http://localhost:3001/api/internal/partner-webhook

# Auth — OBBLIGATORIO in tutti gli ambienti (min 32 caratteri, cambia in prod!)
# Genera con: openssl rand -base64 32
AUTH_SECRET=CAMBIA-ME-con-openssl-rand-base64-32-minimo32chars!
API_JWT_ISSUER=varco-web
# Webhook partner — OBBLIGATORIO, cambia in prod
PARTNER_WEBHOOK_SECRET=CAMBIA-ME-webhook-secret-in-prod

# Porte applicazioni
WEB_PORT=3000
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
# URL server API — NON usare NEXT_PUBLIC_ (non deve finire nel bundle client)
API_URL=http://localhost:3001/api
