{
  "name": "@varco/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Job asincroni — sync catalogo, classificazione SKU, generazione documenti",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json && node --env-file=../../.env --watch dist/index.js",
    "start": "node --env-file=../../.env dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "enqueue:demo-sync": "node --env-file=../../.env --import tsx src/scripts/enqueue-demo-sync.ts",
    "populate:demo": "node --env-file=../../.env --import tsx src/scripts/populate-demo-workflow.ts"
  },
  "dependencies": {
    "@varco/classification": "workspace:*",
    "@varco/documents": "workspace:*",
    "@varco/database": "workspace:*",
    "@varco/matrix": "workspace:*",
    "@varco/queue": "workspace:*",
    "@varco/shared": "workspace:*",
    "bullmq": "^5.79.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@varco/tsconfig": "workspace:*",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
