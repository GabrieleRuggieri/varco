{
  "name": "@varco/api",
  "version": "0.0.0",
  "private": true,
  "description": "Backend REST — catalogo, matrice, checklist, documenti, partner",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json && node --watch dist/main.js",
    "start": "node dist/main.js",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@varco/database": "workspace:*",
    "@varco/shared": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.3",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.29",
    "@varco/tsconfig": "workspace:*",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
