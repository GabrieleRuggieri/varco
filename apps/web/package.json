{
  "name": "@varco/web",
  "version": "0.0.0",
  "private": true,
  "description": "Dashboard Next.js — checklist, catalogo, documenti",
  "scripts": {
    "build": "next build",
    "dev": "node --env-file=../../.env ./node_modules/next/dist/bin/next dev --port ${WEB_PORT:-3000}",
    "start": "node --env-file=../../.env ./node_modules/next/dist/bin/next start --port ${WEB_PORT:-3000}",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@varco/auth": "workspace:*",
    "@varco/database": "workspace:*",
    "@varco/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^3.3.11",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.29",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@varco/tsconfig": "workspace:*",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
